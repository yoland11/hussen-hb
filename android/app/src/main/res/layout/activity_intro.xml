<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/intro_background"
    android:clipToPadding="false">

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-72dp"
        android:layout_marginTop="-40dp"
        android:background="@drawable/intro_orb_gold" />

    <View
        android:layout_width="230dp"
        android:layout_height="230dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-58dp"
        android:layout_marginBottom="120dp"
        android:background="@drawable/intro_orb_green" />

    <LinearLayout
        android:id="@+id/intro_card"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="32dp"
        android:background="@drawable/glass_panel"
        android:elevation="24dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="22dp"
        android:paddingBottom="26dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginBottom="-54dp"
            android:background="@drawable/glass_sheen" />

        <ImageView
            android:id="@+id/intro_logo"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/app_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/app_name"
            android:textColor="@color/intro_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/intro_subtitle"
            android:textColor="@color/intro_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
